#!/bin/bash

echo "Iniciando servidor local na porta 3000 com COOP e COEP ativados..."

python3 -c "
import http.server
import socketserver

class SafeHTTPRequestHandler(http.server.SimpleHTTPRequestHandler):
    def end_headers(self):
        self.send_header('Cross-Origin-Opener-Policy', 'same-origin')
        self.send_header('Cross-Origin-Embedder-Policy', 'require-corp')
        super().end_headers()

port = 3000
with socketserver.TCPServer(('0.0.0.0', port), SafeHTTPRequestHandler) as httpd:
    print(f'Servidor rodando em: http://localhost:{port}')
    httpd.serve_forever()
"